<html>
  <head>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-eOJMYsd53ii+scO/bJGFsiCZc+5NDVN2yr8+0RDqr0Ql0h+rP48ckxlpbzKgwra6"
      crossorigin="anonymous"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-JEW9xMcG8R+pH31jmWH6WWP0WintQrMb4s7ZOdauHnUtxwoG2vI5DkLtS3qm9Ekf"
      crossorigin="anonymous"
    ></script>
    <title>OWASP Juice Shop - Open Source Statistics</title>

    <style>
      .box {
        position: relative;
        width: 100%;
        height: 500px;
        display: flex;
        justify-content: center;
        overflow: hidden;
      }

      .graph {
        width: 50%;
        float: left;
        margin: 0 0 5px;
      }

      .wide {
        width: 100%;
        float: left;
        margin: 0;
        /* margin-left:2%;
            margin-right: 2%;
            margin-bottom: 5px; */
        padding: 1rem 1rem;
      }

      body {
        text-align: center;
        /* background-color: #212529; */
      }

      .card {
      }

      .spam-container {
        width: 60vw;
        height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
      }
    </style>
    <script
      type="text/javascript"
      src="https://www.gstatic.com/charts/loader.js"
    ></script>
    <script type="text/javascript">
      let npm = "<%= npm %>"
      let sf = "<%= sourceForge %>"
      let docJs = "<%= dockerJs %>"
      let docJsCtf = "<%= dockerJsCtf %>"
      let github = "<%= github %>"
      let githubReleases = "<%= githubReleases %>"
      githubReleases = parseInt(githubReleases, 10)
      let categories = "<%=categories%>"
      let tags = "<%=tags%>"
      let spamStats = <%- JSON.stringify(spamStats) %>;
      let dockerImageSizes = <%- JSON.stringify(dockerImageSizes) %>;
      let challengeCounts = <%- JSON.stringify(challengeCounts) %>;
    </script>
    <script type="text/javascript" src="script.js"></script>
  </head>

  <body>
    <nav class="navbar navbar-light bg-dark">
      <div class="container-fluid">
        <a href="https://owasp-juice.shop"
          ><img
            src="https://avatars.githubusercontent.com/u/83415759?s=200&v=4"
            alt=""
            width="60"
            height="60"
            class="d-inline-block align-text-top"
        /></a>
        <span style="color: white; font-size: large"
          >OWASP Juice Shop - Open Source Statistics</span
        >
      </div>
    </nav>
    <br /><br />
    <div class="wide">
      <div class="card">
        <!-- This Graph shows the Github downloads for the juice-shop app -->
        <div class="card-body">
          <br /><br />
          <div id="gh" class="box"></div>
        </div>
      </div>
    </div>

    <div class="wide">
      <div class="card">
        <!-- This Graph shows the Docker pulls for the juice-shop app. -->
        <div class="card-body">
          <br /><br />
          <div id="docJs" class="box"></div>
        </div>
      </div>
    </div>

    <div class="wide">
      <div class="card">
        <!-- This Graph shows the Source Forge downloads for the juice-shop app. -->
        <div class="card-body">
          <br /><br />
          <div id="sf" class="box"></div>
        </div>
      </div>
    </div>

    <div class="container graph">
      <div class="card">
        <!-- This Graph shows the npm downloads for the juice-shop-ctf-cli package. -->
        <div class="card-body">
          <br /><br />
          <div id="npm" class="box"></div>
        </div>
      </div>
    </div>

    <div class="container graph">
      <div class="card">
        <!-- This Graph shows the Docker pulls for the juice-shop Ctf Extension. -->
        <div class="card-body">
          <br /><br />
          <div id="docJsCtf" class="box"></div>
        </div>
      </div>
    </div>
    <div class="container graph">
      <div class="card">
        <!-- This Graph shows the number of challenges per tag -->
        <div class="card-body">
          <br /><br />
          <div id="tags" class="box"></div>
        </div>
      </div>
    </div>
    <div class="container graph">
      <div class="card">
        <!-- This Graph shows the number of challenges per category -->
        <div class="card-body">
          <br /><br />
          <div id="categories" class="box"></div>
        </div>
      </div>
    </div>

    <div class="wide">
      <div class="card">
        <!-- This Graph shows the number of spam issues and PRs for the juice-shop app. -->
        <div class="card-body">
          <div id="spamChart" class="box"></div>
        </div>
      </div>
    </div>

    <div class="wide">
      <div class="card">
        <div class="card-body">
          <br /><br />
          <h5 class="card-title">Frontend Bundle Analysis</h5>
          <img src="https://raw.githubusercontent.com/juice-shop/juice-shop/refs/heads/master/screenshots/bundle-analysis.png" alt="Bundle Analysis" class="img-fluid" style="max-width: 100%; height: auto;" />
          <br /><br />
        </div>
      </div>
    </div>

    <!-- Release History Comparisons -->
    <div class="wide">
      <h3 class="mt-4 mb-3">Release History Comparisons</h3>
      <div class="card">
        <div class="card-body">
          <br /><br />
          <div style="position: relative;">
            <span title="Versions not shown have since been removed or cleaned up by Docker Hub, or did not have a Docker image. v1.0.0 was backported as a re-release for the 10th year anniversary." style="cursor: help; position: absolute; top: 2px; right: 8px; z-index: 1; font-size: 1.2rem; color: #6c757d;">&#9432;</span>
            <div id="dockerImageSizes" class="box"></div>
          </div>
        </div>
      </div>
      <div class="card mt-3">
        <div class="card-body">
          <br /><br />
          <div id="challengeCounts" class="box"></div>
        </div>
      </div>
    </div>
  </body>
</html>
